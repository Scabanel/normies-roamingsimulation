{
  "name": "normies-roamingsimulation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cp node_modules/world-atlas/countries-110m.json public/world-110m.json && (tsx scripts/export-static.ts || true) && next build",
    "start": "next start",
    "lint": "eslint",
    "index": "tsx scripts/index-normies.ts",
    "index:dev": "tsx scripts/index-normies.ts -- --limit 500",
    "index:holders": "tsx scripts/update-holders.ts",
    "index:holders:all": "tsx scripts/update-holders.ts --all",
    "export:static": "tsx scripts/export-static.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "better-sqlite3": "^12.8.0",
    "d3-geo": "^3.1.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.183.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
